---
import PageLayout from '../layout/PageLayout.astro';
---

<PageLayout title="Inicio - Sistema de Facuración PRO">
  <main class="flex flex-col items-center justify-center p-4 gap-4 h-[calc(100vh-5rem)] overflow-hidden">
    <div class="max-w-5xl text-center flex flex-col items-center gap-4">
      <div class="p-3 bg-indigo-600 rounded-xl shadow-lg shadow-indigo-500/30">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-blue-500 tracking-tight dark:from-indigo-400 dark:to-blue-300">
        Sistema de Facturación PRO
      </h1>
      
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed font-medium max-w-3xl">
        La solución definitiva para gestionar el crecimiento de tu PyME y emitir facturas en segundos de manera segura.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-2 w-full text-left">
        <div class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-none border border-gray-100 dark:border-gray-700">
          <div class="text-indigo-500 mb-2 text-2xl">🛡️</div>
          <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-1">Seguridad Total</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Autenticación inviolable.</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-none border border-gray-100 dark:border-gray-700">
          <div class="text-indigo-500 mb-2 text-2xl">📦</div>
          <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-1">Control de Inventario</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Gestión de stock en tiempo real.</p>
        </div>
        <div class="bg-white dark:bg-gray-800 p-5 rounded-2xl shadow-xl shadow-gray-200/50 dark:shadow-none border border-gray-100 dark:border-gray-700">
          <div class="text-indigo-500 mb-2 text-2xl">🚀</div>
          <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-1">Ventas Rápidas</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Módulo diseñado para kioscos.</p>
        </div>
      </div>

      <div class="mt-6 flex flex-wrap justify-center items-center gap-4 w-full">
        <a href="/login" class="px-8 py-3 rounded-xl bg-indigo-600 text-white font-bold text-lg shadow-lg hover:scale-105 active:scale-95 transition-transform">
          Iniciar Sesión
        </a>
        <a href="/signup" class="px-8 py-3 rounded-xl bg-white dark:bg-gray-800 text-indigo-600 dark:text-indigo-400 border-2 border-indigo-100 dark:border-gray-700 font-bold text-lg hover:scale-105 active:scale-95 transition-transform">
          Registrar mi PyME
        </a>
      </div>
    </div>
  </main>
</PageLayout>
