---
import Button from '../components/Button.astro';
import Spinner from '../components/Spinner.astro';
import PageLayout from '../layout/PageLayout.astro';
---

<PageLayout title="Registro - FacturacionApp">
  <div class="flex items-center justify-center min-h-[calc(100vh-5rem)]">
    <form
      id="signup-form"
      class="p-8 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 shadow-xl w-full max-w-sm flex flex-col gap-6"
    >
      <div class="text-center">
        <div class="mx-auto w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Crear cuenta</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Registra tu PyME en el sistema</p>
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="email" class="text-sm font-medium text-gray-700 dark:text-gray-300">Correo</label>
        <div class="relative">
          <input
            type="email"
            id="email"
            class="w-full bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg py-2.5 px-3 pr-10 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500"
            placeholder="tu@correo.com"
          />
          <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
            <ion-icon id="email-check" name="checkmark-circle" class="text-green-500 text-xl hidden"></ion-icon>
            <ion-icon id="email-cross" name="close-circle" class="text-red-500 text-xl hidden"></ion-icon>
          </div>
        </div>
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="password" class="text-sm font-medium text-gray-700 dark:text-gray-300">Contraseña</label>
        <div class="relative">
          <input
            type="password"
            id="password"
            class="w-full bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg py-2.5 px-3 pr-10 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500"
            placeholder="••••••••"
          />
          <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
            <ion-icon id="password-check" name="checkmark-circle" class="text-green-500 text-xl hidden"></ion-icon>
            <ion-icon id="password-cross" name="close-circle" class="text-red-500 text-xl hidden"></ion-icon>
          </div>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400">
          Min 8 caracteres, 1 mayúscula, 1 minúscula, 1 número.
        </p>
      </div>

      <button
        type="submit"
        class="flex justify-center items-center gap-4 w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 px-4 rounded-lg transition-all hover:scale-[1.02] active:scale-95 cursor-pointer shadow-lg shadow-indigo-500/25"
      >
        Crear cuenta
        <Spinner color="fill-indigo-800" />
      </button>

      <p class="text-center text-sm text-gray-500 dark:text-gray-400">
        ¿Ya tienes cuenta? <a href="/login" class="text-indigo-600 dark:text-indigo-400 font-medium hover:underline">Inicia sesión</a>
      </p>
    </form>
  </div>
</PageLayout>

<script>
  // Validation Regex Variables
  import { z } from 'astro/zod';
  import ky, { HTTPError } from 'ky';
  import { showToast } from '../components/notification/notification';

  const formUserSchema = z.object({
    email: z.email({ error: 'Tiene que ser un email valido' }),
    password: z.string().regex(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)[a-zA-Z\d\S]{8,}$/, {
      error: 'Recuerda cumplir los requerimientos de la contraseña',
    }),
  });

  // DOM Elements
  const form = document.querySelector('#signup-form');
  const emailInput = document.querySelector('#email');
  const passwordInput = document.querySelector('#password');
  const spinner = document.querySelector('#spinner');

  // Reusable validation function
  function validateField(inputElement, success) {
    const nextDiv = inputElement.nextElementSibling;
    const checkIcon = nextDiv.children[0];
    const crossIcon = nextDiv.children[1];
    const value = inputElement.value;

    if (value.length === 0) {
      checkIcon.classList.add('hidden');
      crossIcon.classList.add('hidden');
      return;
    }

    if (success) {
      checkIcon.classList.remove('hidden');
      crossIcon.classList.add('hidden');
    } else {
      checkIcon.classList.add('hidden');
      crossIcon.classList.remove('hidden');
    }
  }

  emailInput.addEventListener('input', () => {
    const { success } = formUserSchema.pick({ email: true }).safeParse({ email: emailInput.value });
    validateField(emailInput, success);
  });

  passwordInput.addEventListener('input', () => {
    const { success } = formUserSchema
      .pick({ password: true })
      .safeParse({ password: passwordInput.value });
    console.log(success);

    validateField(passwordInput, success);
  });

  // Submit Placeholder
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Check if both fields are valid before proceeding
    const { success, error } = formUserSchema.safeParse({
      email: emailInput.value,
      password: passwordInput.value,
    });
    const fieldErrors = error?.flatten().fieldErrors;

    if (success) {
      console.log('Form is valid! Ready to submit.');
      const payload = {
        email: emailInput.value,
        password: passwordInput.value,
      };
      try {
        spinner?.classList.remove('hidden');
        const response = await ky.post('/api/user', { json: payload }).json();
        showToast({
          type: 'success',
          text: `Usuario creado con éxito! Se ha enviado un correo de verificación a ${response.email}`,
        });
      } catch (error) {
        if (error instanceof HTTPError) {
          const errorText = error.data.error;
          showToast({
            type: 'error',
            text: errorText,
          });
        }
      } finally {
        spinner?.classList.add('hidden');
      }
    } else {
      validateField(emailInput, !fieldErrors?.email);
      validateField(passwordInput, !fieldErrors?.email);
    }
  });
</script>
