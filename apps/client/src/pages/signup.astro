---
import PageLayout from "../layout/PageLayout.astro";
---

<PageLayout title="Registro en Facturación">
  <div class="flex items-center justify-center min-h-screen">
  <form id="signup-form" class="bg-white p-8 rounded-lg shadow-md w-full max-w-sm flex flex-col gap-6">
    <h2 class="text-2xl font-bold text-gray-800 text-center">Registrar Usuario</h2>

    <div class="relative flex flex-col gap-1">
      <label for="nombre" class="text-sm font-medium text-gray-700">Nombre Completo</label>
      <input type="text" id="nombre" class="w-full border border-gray-300 rounded-md py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ej. Carlos Montaño" />
    </div>

    <div class="relative flex flex-col gap-1">
      <label for="usuario" class="text-sm font-medium text-gray-700">Nombre de Usuario</label>
      <input type="text" id="usuario" class="w-full border border-gray-300 rounded-md py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ej. carlos_admin" />
    </div>

    <div class="relative flex flex-col gap-1">
      <label for="password" class="text-sm font-medium text-gray-700">Contraseña</label>
      <input type="password" id="password" class="w-full border border-gray-300 rounded-md py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="••••••••" />
    </div>

    <div class="relative flex flex-col gap-1">
      <label for="rol" class="text-sm font-medium text-gray-700">Rol del Usuario</label>
      <select id="rol" class="w-full border border-gray-300 rounded-md py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500">
        <option value="Administrador">Administrador</option>
        <option value="Vendedor">Vendedor</option>
      </select>
    </div>

    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-md transition-colors">
      Registrar e Ir al Login
    </button>

    <p class="text-center text-sm"><a href="/login" class="text-blue-500 font-bold hover:underline">¿Ya tienes cuenta? Inicia Sesión</a></p>
  </form>
  </div>
</PageLayout>

<script>
  import ky, {HTTPError} from 'ky';
  import { showToast } from '../components/notification/notification';

  const form = document.querySelector('#signup-form');
  const nombreInput = document.querySelector('#nombre');
  const usuarioInput = document.querySelector('#usuario');
  const passwordInput = document.querySelector('#password');
  const rolInput = document.querySelector('#rol');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if(!nombreInput.value || !usuarioInput.value || passwordInput.value.length < 6) {
      alert("Por favor llena todos los campos, contraseña mínimo 6 caracteres.");
      return;
    }

    const payload = {
      nombre: nombreInput.value,
      usuario: usuarioInput.value,
      password: passwordInput.value,
      rol: rolInput.value
    };

    try {
      const response = await ky.post('/api/user', {json: payload}).json();
      alert("Usuario creado exitosamente. ¡Puedes iniciar sesión!");
      window.location.href = '/login';
    } catch (error) {
      if (error instanceof HTTPError) {
        const errorData = await error.response.json();
        alert(errorData.error || "Hubo un error");
      }      
    }
  });
</script>
