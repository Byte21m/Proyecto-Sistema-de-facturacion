---
import PageLayout from '../layout/PageLayout.astro';
---

<PageLayout title="Iniciar Sesión - FacturacionApp">
  <div class="flex items-center justify-center min-h-[calc(100vh-5rem)]">
    <form
      id="signup-form"
      class="p-8 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 shadow-xl w-full max-w-sm flex flex-col gap-6"
    >
      <div class="text-center">
        <div class="mx-auto w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100">Iniciar sesión</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Accede a tu panel de facturación</p>
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="email" class="text-sm font-medium text-gray-700 dark:text-gray-300">Correo</label>
        <input
          type="email"
          id="email"
          placeholder="tu@correo.com"
          class="w-full bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg py-2.5 px-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500"
        />
      </div>

      <div class="relative flex flex-col gap-1">
        <label for="password" class="text-sm font-medium text-gray-700 dark:text-gray-300">Contraseña</label>
        <input
          type="password"
          id="password"
          placeholder="••••••••"
          class="w-full bg-gray-50 dark:bg-gray-800 border border-gray-300 dark:border-gray-700 rounded-lg py-2.5 px-3 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-colors text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 px-4 rounded-lg transition-all hover:scale-[1.02] active:scale-95 cursor-pointer shadow-lg shadow-indigo-500/25"
      >
        Iniciar sesión
      </button>

      <p class="text-center text-sm text-gray-500 dark:text-gray-400">
        ¿No tienes cuenta? <a href="/signup" class="text-indigo-600 dark:text-indigo-400 font-medium hover:underline">Regístrate</a>
      </p>
    </form>
  </div>
</PageLayout>

<script>
  import ky, { HTTPError } from 'ky';
  import { showToast } from '../components/notification/notification';

  // DOM Elements
  const form = document.getElementById('signup-form');
  const emailInput = document.getElementById('email');
  const passwordInput = document.getElementById('password');

  // Submit Placeholder
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const payload = {
      email: emailInput.value,
      password: passwordInput.value,
    };
    try {
      await ky.post('/api/auth/login', { json: payload }).json();
      location.assign('/contacts');
    } catch (error) {
      if (error instanceof HTTPError) {
        showToast({ type: 'error', text: error.data.error || 'Error al iniciar sesión' });
      }
    }
  });
</script>
